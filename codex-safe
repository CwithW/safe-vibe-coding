#!/bin/bash
set -euo pipefail

readonly IMAGE_NAME="cwithw/safe-vibe-coding-base:latest"
readonly CONTAINER_PREFIX="safe-vibe-coding-codex"
readonly DOCKER_SOCKET="/var/run/docker.sock"
readonly CONTAINER_DOCKER_SOCKET="/var/run/docker-real.sock"
readonly CODEX_HOME_DIR="${HOME}/.codex"
readonly CONTAINER_HOME_DIR="/home/cw"

generate_uuid() {
    if [ -r "/proc/sys/kernel/random/uuid" ]; then
        cat "/proc/sys/kernel/random/uuid"
        return
    fi

    if command -v uuidgen >/dev/null 2>&1; then
        uuidgen
        return
    fi

    echo "Failed to generate UUID: neither /proc/sys/kernel/random/uuid nor uuidgen is available." >&2
    exit 1
}

sanitize_path_for_name() {
    printf '%s' "$1" \
        | sed 's|/|-|g; s|^-*||; s|[^a-zA-Z0-9_.-]|-|g; s|-\\{2,\\}|-|g'
}

main() {
    local current_dir
    local uuid
    local path_component
    local container_name

    current_dir="$(pwd)"

    if [ ! -S "${DOCKER_SOCKET}" ]; then
        echo "Docker socket not found at ${DOCKER_SOCKET}." >&2
        exit 1
    fi

    mkdir -p "${CODEX_HOME_DIR}"

    uuid="$(generate_uuid)"
    path_component="$(sanitize_path_for_name "${current_dir}")"
    container_name="${CONTAINER_PREFIX}-${path_component}-${uuid}"

    exec docker run -it --rm \
        --network host \
        -w "${current_dir}" \
        -v "${DOCKER_SOCKET}:${CONTAINER_DOCKER_SOCKET}" \
        -v "${CODEX_HOME_DIR}:${CONTAINER_HOME_DIR}/.codex" \
        -v "${current_dir}:${current_dir}" \
        --name "${container_name}" \
        "${IMAGE_NAME}" \
        codex --yolo "$@"
}

main "$@"
